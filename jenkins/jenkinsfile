pipeline{
    agent any
    stages{

        stage("cleanup"){
             steps{
              cleanWs()
             }
        }

        stage("checkout scm"){
               steps{
                  checkout scm
               }
           }
        stage("first stage"){
            steps{
                sh "pwd"
                sh "ls"
                sh "cat fold/new"
                 
                dir("fold"){
                 sh "pwd"
                 sh "ls"   
                }
               
            }
        }
        stage("second stage"){
            steps{
                dir("fold"){
                    sh "echo ahmed >> file.txt"
                }
               
                
            }
        }
    }
}
