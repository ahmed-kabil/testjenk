pipeline{
    agent any
    stages{

        stage("first stage"){
            steps{
                sh "pwd"
                sh "ls"
                sh "cat fold/new"
                 
                dir("fold"){
                 sh "pwd"
                 sh "ls"   
                }
               
            }
        }
        stage("second stage"){
            steps{
                dir("fold"){
                    sh "echo ahmed > file.txt"
                }
               
                
            }
        }
    }
}
